+  });
+
+  test("G4 pre-mutation compare-and-swap (AI-2058) is active on the dispatch path", async () => {
+    const res = await request(appState.app).get("/health");
+    expect(res.body.dispatchIntegrity?.preMutationCAS?.active).toBe(true);
+  });
+});
