+    const agentsFile = path.join(dir, "agents.json");
+    fs.writeFileSync(agentsFile, JSON.stringify({ agents: [SAMPLE_AGENT] }), "utf8");
+    process.env.AGENTS_FILE = agentsFile;
+    reloadAgents();
+    appState = createApp({
